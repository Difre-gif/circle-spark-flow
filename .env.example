# Frontend-safe Supabase configuration
VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-or-publishable-key"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# Local-only privileged tooling credentials.
# Put these in .env.local; never commit real values.
SUPABASE_ACCESS_TOKEN="sbp_your_personal_access_token"
SUPABASE_PROJECT_REF="your-project-ref"
SUPABASE_PROJECT_NAME="your-project-name"
SUPABASE_ORG_ID="your-organisation-id"
